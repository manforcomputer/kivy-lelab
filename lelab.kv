BoxLayoutExemple:

<BoxLayoutExemple>:
    orientation: "horizontal"
    Button:
        text: "A"
        size_hint: .5, None
        #size: "100dp", "60dp"
        height: "60dp"
        pos_hint: { "top": 1 }
    BoxLayout:
        spacing: "10dp"
        orientation: "vertical"
        Button:
            text: "B1"
        Button:
            text: "B2"
        Button:
            text: "B3"
        Button:
            text: "B4"
    Label:
        text: "C"


<MainWidget>:
    Button:
        text: "Hello"
        size: "100dp", "60dp"
        pos: "200dp", "100dp"
        color: 0, 0, 1, 1
    Label:
        text: "Hello2"
        size: "100dp", "60dp"
        pos: "400dp", "200dp"
        color: 1, 0, 0, 1